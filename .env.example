# OpenAI Configuration
OPENAI_API_KEY=sk-...

# Qwen Configuration - Multiple backends supported

# Official Qwen API (default backend)
QWEN_API_KEY=...

# OpenRouter backend (use: provider=qwen-openrouter)
OPENROUTER_API_KEY=sk-or-...

# Fireworks backend (use: provider=qwen-fireworks)
FIREWORKS_API_KEY=...

# Default provider (openai or qwen)
CUH_DEFAULT_PROVIDER=openai

# Default model
CUH_DEFAULT_MODEL=gpt-5.4

# Telemetry (disabled by default)
CUH_TELEMETRY_ENABLED=false

# Log level
CUH_LOG_LEVEL=INFO